      <aliases enabled='yes' />
      <column caption='No. of Bookings' datatype='integer' name='[Calculation_1220196583489542]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([is_canceled])' />
      </column>
      <column caption='# count of cancellation' datatype='integer' name='[Calculation_1220196583706631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_canceled] = &quot;Yes&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='No. of cancellations' datatype='integer' name='[Calculation_1220196584865801]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Calculation_1220196583706631])' />
      </column>
      <column caption='Cancellation rate' datatype='real' name='[Calculation_1220196585504778]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [is_canceled] = &quot;Yes&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([is_canceled])' />
      </column>
      <column caption='Avg Daily Revenue' datatype='real' name='[Calculation_1220196586733579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='avg([adr])' />
      </column>
      <column caption='count(Online TA)' datatype='integer' name='[Calculation_1220196600614926]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [market_segment] = &quot;Online TA&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Max.Market segment' datatype='integer' name='[Calculation_1220196602036240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Calculation_1220196600614926])' />
      </column>
      <column caption='Key Insights' datatype='string' name='[Calculation_1220196638224401]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;• August recorded the highest number of bookings (2,604).&#13;&#10;&#13;&#10;• Portugal (PRT) generated the highest number of bookings with 9,282 reservations.&#13;&#10;&#13;&#10;• The overall cancellation rate was 44.84%, indicating a significant proportion of bookings were cancelled.&#13;&#10;&#13;&#10;• BB meal plan was the most preferred option, accounting for 13,983 bookings.&#13;&#10;&#13;&#10;• Confirmed bookings (9,767) exceeded cancelled bookings (7,940).&quot;' />
      </column>
